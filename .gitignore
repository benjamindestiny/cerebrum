.env
.env.local
.env.production

# Build outputs
build/
dist/
*.js.map
*.min.js

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Docker volumes
mongodb_data/
redis_data/

# SSL certificates
*.pem
*.key
*.crt